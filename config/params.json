{
    "data": {
        "train_path": "./datasets/Train_with_target.csv",
        "test_path": "./datasets/Test_with_target.csv"
    },
    "preprocess": {
        "anomaly_lower": 0.01,
        "anomaly_upper": 0.99
    },
    "model": {
        "objective": "binary",
        "metric": "auc",
        "boosting_type": "gbdt",
        "learning_rate": 0.05,
        "num_leaves": 31,
        "random_state": 42,
        "verbose": 1,
        "num_boost_round": 100,
        "early_stopping_rounds": 10
    },
    "save": {
        "model_path": "./models/lightgbm_trained.pkl",
        "scaler_path": "./models/lightgbm_scaler.pkl"
    }
}